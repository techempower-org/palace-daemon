[Unit]
Description=palace-daemon — MemPalace HTTP/MCP gateway
After=network.target

[Service]
Type=notify
NotifyAccess=main
User=user
WorkingDirectory=/home/user/palace-daemon
ExecStartPre=-/usr/bin/fuser -k 8085/tcp
ExecStartPre=-/usr/bin/rm -f /home/user/.cache/palace-daemon/daemon-8085.lock
ExecStart=/home/user/.local/share/pipx/venvs/mempalace/bin/python main.py
# After the daemon binds, probe /search for the empty-HNSW warning and
# auto-trigger /repair {mode:rebuild} in the background if detected.
# Idempotent + non-blocking — see scripts/auto-repair-if-empty.sh.
ExecStartPost=/home/user/palace-daemon/scripts/auto-repair-if-empty.sh
Restart=on-failure
RestartSec=5
WatchdogSec=120
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1
Environment=PALACE_MAX_READ_CONCURRENCY=4
Environment=PALACE_MAX_WRITE_CONCURRENCY=1
# CRITICAL: the daemon hosts mempalace's MCP server in-process. If
# PALACE_DAEMON_URL leaks into this process (e.g. via a shared
# EnvironmentFile that's also sourced by client tools), mempalace's
# mcp_server detects it and forwards every /mcp call back to the
# daemon — recursive self-call that deadlocks at the 120s timeout.
# Setting STRICT=0 here forces the in-process path regardless of
# whether DAEMON_URL leaks in. See palace-daemon#11.
Environment=PALACE_DAEMON_STRICT=0

[Install]
WantedBy=multi-user.target
